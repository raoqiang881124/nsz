{
  "name": "nsz-binary-build",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "workspaceFolder": "/workspaces/nsz",
  "remoteUser": "vscode",
  "remoteEnv": {
    "PATH": "/opt/venv-linux/bin:${containerEnv:PATH}"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "charliermarsh.ruff",
        "ms-python.python"
      ]
    }
  }
}